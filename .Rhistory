#descriptive statistics
library(psych)
describe(student)
#statistics for final grade
describe(student$G3)
numeric_data <- student[,sapply(student, is.numeric)]
cor_matrix <- cor(numeric_data)
round(cor_matrix,2)
library(corrplot)
corrplot(
cor_matrix,
method = "color",
type = "upper",
tl.color = "black",
tl.cex = 0.7)
sort(cor_matrix[,"G3"], decreasing = T)
corrplot(
cor_matrix,
method = "color",
type = "upper",
tl.col = "black",
tl.cex = 0.7)
sort(cor_matrix[,"G3"], decreasing = T)
cov(numeric_data)
write.csv2(
cor_matrix,
"output/correlation_matrix.csv"
)
write.csv2(
cor_matrix,
"output/correlation_matrix.csv"
)
write.csv(
cor_matrix,
"output/correlation_matrix.csv"
)
#saving
write.csv(
student,
"output/student_clean.csv",
row.names = F
)
summary(model)
model <- lm(
g3 ~ studytime + absence + G1 + G2 + faliures + age,
data = student
)
model <- lm(
G3 ~ studytime + absence + G1 + G2 + faliures + age,
data = student
)
model <- lm(
G3 ~ studytime + absences + G1 + G2 + faliures + age,
data = student
)
model <- lm(
G3 ~ studytime + absences + G1 + G2 + failures + age,
data = student
)
#view model
summary(model)
#confidence interval
confint(model)
#view model
summary(model)
head(student[,c("G3", "Predicted_G3")])
student$Predicted_G3 <- predict(model)
head(student[,c("G3", "Predicted_G3")])
ggplot(student, aes(x= G3, y = Predicted_G3))+
geom_point(color = "blue")+
geom_abline(intercept = 0, slope = 1, color = "red")+
labs(
title = "Actual VS Predicted Final Grades",
x = "Actual Grades",
y = "Predicted Grade"
)+
theme_minimal()
ggplot(student, aes(x = Predicted_G3, y = residuals(model)))+
geom_point()+
geom_hline(yintercept = 0, color = "red")+
labs(
title = "Residual Plot",
x = "Predicted Grades",
y = "Residuals"
)+
theme_minimal()
write.csv(student,
"output/student_predictions.csv",
row.names = F)
t.test(G3 ~ sex, data = student)
summary(anova_model)
student$studytime <- as.factor(student$studytime)
anova_model <- aov(G3 ~ studytime, data = student)
summary(anova_model)
student$GradeCategory <- ifelse(student$G3 >= 10, "Pass", "Fail")
student$GradeCategory <- as.factor(student$GradeCategory)
chisq.test(table(student$internet, student$GradeCategory))
capture.output(
t.test(G3 ~ sex, data = student),
file = "output/t_test_result.txt"
)
capture.output(
summary(anova_model),
file = "output/anova_results.txt"
)
library(shiny)
# 1. Define the look of the app
ui <- fluidPage(
sliderInput("num", "Choose a number", 1, 100, 50),
plotOutput("hist")
)
# 2. Define the logic behind the app
server <- function(input, output) {
output$hist <- renderPlot({
hist(rnorm(input$num)) # Re-plots every time the slider moves
})
}
# 3. Run the application
shinyApp(ui = ui, server = server)
